# ─────────────────────────────────────────────────────────────────────
# Backend FastAPI — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ─────────────────────────────────────────────────────────────────────

# Token do painel admin (mude em produção!)
ADMIN_TOKEN=M0rTh3

# Em produção (Render com disco persistente): /data
# Em desenvolvimento: deixe vazio (usa api/ local)
DATA_DIR=/data

# Caminho para o arquivo JSON da Service Account do Google
# Em produção: coloque o arquivo em DATA_DIR e aponte aqui
GOOGLE_SA_PATH=/data/morthe-service-account.json

# URL do frontend (Vercel) — usada no CORS
FRONTEND_URL=https://seu-site.vercel.app

# ID da pasta raiz do Google Drive (slideshow legado, opcional)
DRIVE_FOLDER_ID=1fQzGW9Kg4-kG3SqMsMbOBNF3AWJ2SGeI
